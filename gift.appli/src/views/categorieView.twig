<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giftbox - Catégories</title>
</head>
<body>
    <h1>Liste des catégories</h1>
    <ul>
        {% for categorie in categories %}
            <li>
                <a href="{{ url_for('categorie', {'id': categorie.id}) }}">{{ categorie.id }} - {{ categorie.libelle }} - {{ categorie.description }}</a>
            </li>
        {% endfor %}
    </ul>
</body>
</html>
