{% extends 'layout.twig' %}

{% block title %}Giftbox - Catégorie{% endblock %}

{% block content %}
    <h1>Détail de la catégorie</h1>

    <p>{{ id }} - {{ libelle }} - {{ description }}</p>

    <p>
        <a href="{{ url_for('categorie_prestations', {'id': id}) }}">
            Voir les prestations de cette catégorie
        </a>
    </p>

    <p>
        <a href="{{ url_for('categories') }}">
            Retour à la liste des catégories
        </a>
    </p>
{% endblock %}