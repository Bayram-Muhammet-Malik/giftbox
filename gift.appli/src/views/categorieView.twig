{% extends 'layout.twig' %}

{% block title %}Liste des catégories{% endblock %}

{% block content %}
    <h2>Liste des catégories</h2>
    <ul>
        {% for categorie in categories %}
            <li>
                <a href="{{ url_for('categorieID', {'id': categorie.id}) }}">
                    {{ categorie.libelle }}
                </a>
            </li>
        {% endfor %}
    </ul>
{% endblock %}