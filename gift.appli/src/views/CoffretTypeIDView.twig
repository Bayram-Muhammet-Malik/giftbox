<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giftbox - Détail coffret type</title>
</head>
<body>
    <h1>{{ coffretType.libelle }}</h1>

    <p>{{ coffretType.description }}</p>
    <p>Thème : {{ coffretType.theme_id }}</p>

    <h2>Liste des prestations</h2>
    <ul>
        {% for prestation in prestations %}
            <li>
                {{ loop.index }} - {{ prestation.libelle }} - {{ prestation.description }}
            </li>
        {% else %}
            <li>Aucune prestation associée à ce coffret type.</li>
        {% endfor %}
    </ul>

    <p>
        <a href="{{ url_for('coffretType') }}">
            Retour à la liste des coffrets types
        </a>
    </p>
</body>
</html>
