{% extends 'layout.twig' %}
{% block title %}Giftbox - Créer une box{% endblock %}

{% block content %}
<h1>Créer une nouvelle box</h1>

<form action="{{ url_for('create_coffret') }}" method="post">

    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

    <input type="text" id="libelle" name="libelle" value="{{ old.libelle ?? '' }}" placeholder="Libellé" required>
    </br>
    <textarea id="description" name="description" placeholder="Description">{{ old.description ?? '' }}</textarea>
    </br>
    <label class="toggle">
    <input type="checkbox" id="kdo" name="kdo" value="1" {% if old.kdo is defined and old.kdo %}checked{% endif %}>
    <span></span>
    </label>
    <span>C'est un cadeau ?</span>
    </br>
    <div id="message_kdo_wrapper" style="display:none;">
        <textarea id="message_kdo" name="message_kdo" placeholder="Message du cadeau">{{ old.message_kdo ?? '' }}</textarea>
        </br>
    </div>
    <button type="submit">Créer la box</button>
    </br>
    </br>
    <a href="{{ url_for('coffret_types') }}">Annuler</a>
</form>

<script>
    const checkbox = document.getElementById('kdo');
    const wrapper = document.getElementById('message_kdo_wrapper');
    const textarea = document.getElementById('message_kdo');

    function toggleMessage() {
        if (checkbox.checked) {
            wrapper.style.display = 'block';
            textarea.setAttribute('required', 'required');
        } else {
            wrapper.style.display = 'none';
            textarea.removeAttribute('required');
        }
    }

    toggleMessage();
    checkbox.addEventListener('change', toggleMessage);
</script>

{% endblock %}
