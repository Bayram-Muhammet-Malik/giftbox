{% extends 'layout.twig' %}
{% block title %}Giftbox - Box créée{% endblock %}
{% block content %}

    <h1>Box créée avec succès !</h1>

    <ul>
        <li><strong>ID :</strong> {{ box.id }}</li>
        <li><strong>Libellé :</strong> {{ box.libelle }}</li>
        <li><strong>Description :</strong> {{ box.description }}</li>
        <li><strong>Cadeau :</strong> {{ box.kdo ? 'Oui' : 'Non' }}</li>
        {% if box.message_kdo %}
            <li><strong>Message cadeau :</strong> {{ box.message_kdo }}</li>
        {% endif %}
    </ul>

    <a href="{{ url_for('create_coffret') }}">Créer une nouvelle box</a>

{% endblock %}