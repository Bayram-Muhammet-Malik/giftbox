{% extends 'layout.twig' %}

{% block title %}Liste des prestations{% endblock %}

{% block content %}
    <h2>Liste des prestations</h2>
    <ul>
        {% for prestation in prestations %}
            <li>
                <a href="{{ url_for('prestation_id', {'id': prestation.id}) }}">
                    {{ prestation.libelle }}
                </a>
            </li>
        {% endfor %}
    </ul>
{% endblock %}